{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(self), microphone=(), geolocation=(self)"
        },
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=63072000; includeSubDomains"
        },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://cdnjs.cloudflare.com; style-src 'self' 'unsafe-inline'; font-src 'self'; img-src 'self' data: blob: https://cdn.flyclean.app; connect-src 'self' https://*.r2.cloudflarestorage.com; frame-src https://flyclean-mapa.vercel.app; frame-ancestors 'none'; base-uri 'self'; form-action 'self'"
        }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/cron-pipeline",
      "schedule": "0 11 * * *"
    },
    {
      "path": "/api/cron-report",
      "schedule": "0 21 * * 5"
    },
    {
      "path": "/api/cron-report",
      "schedule": "0 11 * * 1"
    },
    {
      "path": "/api/cron-db-sync",
      "schedule": "*/10 * * * *"
    },
    {
      "path": "/api/cron-outbox",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/health-reconcile",
      "schedule": "17 4 * * *"
    }
  ],
  "functions": {
    "api/cron-db-sync.js": {
      "maxDuration": 60
    },
    "api/cron-outbox.js": {
      "maxDuration": 60
    },
    "api/health-reconcile.js": {
      "maxDuration": 60
    }
  }
}
