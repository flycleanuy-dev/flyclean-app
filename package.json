{
  "name": "flyclean-app",
  "version": "2.0.0",
  "private": true,
  "description": "FlyClean PWA — Notion proxy + R2 photo uploads + Claude AI receipt OCR",
  "type": "module",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "lint": "eslint api scripts tests",
    "lint:fix": "eslint api scripts tests --fix",
    "format": "prettier --write \"api/**/*.js\" \"scripts/**/*.{js,cjs,mjs}\" \"tests/**/*.mjs\" \"*.json\"",
    "format:check": "prettier --check \"api/**/*.js\" \"scripts/**/*.{js,cjs,mjs}\" \"tests/**/*.mjs\" \"*.json\"",
    "test": "node tests/globals.test.mjs && node tests/no-undef.test.mjs && node tests/calculos.test.mjs && node tests/smoke.mjs && node tests/permisos.mjs",
    "check": "node tests/check-html.mjs",
    "audit": "npm audit --audit-level=high",
    "dev": "vite",
    "build": "node scripts/gen-globals.cjs && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.105.0",
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/s3-request-presigner": "^3.700.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.7.0",
    "prettier": "^3.9.5",
    "vite": "^8.1.4"
  }
}