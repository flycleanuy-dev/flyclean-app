# FlyClean — variables de entorno
# Copiá este archivo a .env.local y completá los valores (NO subas .env.local a git).
# En producción se configuran en el panel de Vercel (Project → Settings → Environment Variables).

# --- Notion (proxy /api/notion) ---
NOTION_TOKEN=

# --- Cloudflare R2 (subida de fotos/recibos, /api/upload-url) ---
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=https://cdn.flyclean.app

# --- Crons (Vercel manda Authorization: Bearer <CRON_SECRET>) ---
CRON_SECRET=

# --- OCR de recibos con Claude (/api/extract-receipt) ---
ANTHROPIC_API_KEY=

# --- Emails (Resend). Sin RESEND_API_KEY, los emails se saltean sin romper. ---
RESEND_API_KEY=
RESEND_FROM=

# --- Validación de PIN del lado del servidor (/api/verify-pin) ---
# JSON con el mapa de id de usuario → PIN. Ej: {"diego-laxalt":"1234","eduardo-cabral":"9999"}
USER_PINS=

# --- Supabase (espejo de LECTURA /api/db + estado compartido del mapa /api/mapa-estado) ---
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
SUPABASE_ANON_KEY=
SUPABASE_JWT_SECRET=

# --- Vercel KV / Upstash REST (rate-limit de PIN y OCR, PINs hasheados, estado del mapa) ---
KV_REST_API_URL=
KV_REST_API_TOKEN=

# --- Admin: CSV de ids que pueden setear/resetear PINs (/api/admin-set-pin). Default: diego-laxalt,eduardo-cabral ---
ADMIN_IDS=

# Tablas Supabase-first (CSV) — debe coincidir con la env de Vercel Production.
# La usa scripts/sync-notion-supabase.mjs (guard fail-closed) y los crons en Vercel.
SUPAFIRST_TABLES=servicios,clientes,propuestas
